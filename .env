APP_NAME = "Bing Wallpaper"
APP_VERSION = 2.0.8

HTTP_HOST = wp.home504.io
HTTP_PORT = 9870
CERT_DIR = ./certs
IMAGE_DIR = /Volumes/1TB/bingwp

LOG_ARGS = "level=info&cycle=daily&comp=0"
LOG_FILE = "rotate://./logs/{{FILE}}?${LOG_ARGS}"

DATABASE_LOG = "rotate://./logs/sql.log?${LOG_ARGS}"
# DATABASE_URL = "immudb://${DB_USER}:${DB_PASS}@127.0.0.1/db_bingwp?sslmode=disable"
DATABASE_URL = "postgres://${DB_USER}:${DB_PASS}@127.0.0.1/db_space?search_path=bingwp,public&sslmode=disable"
# DATABASE_TYPE = "mysql"
# DATABASE_URL = "${DB_USER}:${DB_PASS}@tcp(127.0.0.1)/db_bingwp?parseTime=true&loc=Local"
# DATABASE_TYPE = "turso"
# DATABASE_URL = "data/bingwp.db"
DB_USER = dba
DB_PASS = "pass"
